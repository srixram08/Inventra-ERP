generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// USER MANAGEMENT
// =====================

model User {
  id Int @id @default(autoincrement())

  name String

  email String @unique

  password String

  role Role @default(EMPLOYEE)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

// =====================
// USER ROLES
// =====================

enum Role {
  ADMIN

  MANAGER

  EMPLOYEE
}

// =====================
// CATEGORY MANAGEMENT
// =====================

model Category {
  id Int @id @default(autoincrement())

  name String @unique

  description String?

  products Product[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

// =====================
// PRODUCT MANAGEMENT
// =====================

model Product {
  id Int @id @default(autoincrement())

  name String

  description String?

  sku String @unique

  price Float

  stock Int @default(0)

  categoryId Int

  category Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}
